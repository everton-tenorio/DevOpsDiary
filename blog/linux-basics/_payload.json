592,1241],{"class":49},[43,1594,1595],{"class":97}," -sf",[43,1597,1598],{"class":53}," \"$(",[43,1600,244],{"class":97},[43,1602,1603],{"class":53},")/project/src/config\"",[43,1605,1606],{"class":53}," project/config_link\n",[43,1608,1610],{"class":45,"line":1609},31,[43,1611,67],{"emptyLinePlaceholder":66},[43,1613,1615],{"class":45,"line":1614},32,[43,1616,1617],{"class":484},"# 3. permissions\n",[43,1619,1621,1623],{"class":45,"line":1620},33,[43,1622,1425],{"class":49},[43,1624,1625],{"class":53}," \"Setting permissions\"\n",[43,1627,1629,1631,1633],{"class":45,"line":1628},34,[43,1630,789],{"class":49},[43,1632,811],{"class":97},[43,1634,795],{"class":53},[43,1636,1638,1640,1642],{"class":45,"line":1637},35,[43,1639,789],{"class":49},[43,1641,820],{"class":97},[43,1643,493],{"class":53},[43,1645,1647,1650,1652],{"class":45,"line":1646},36,[43,1648,1649],{"class":49},"ls",[43,1651,682],{"class":97},[43,1653,1654],{"class":53}," project/docs/\n",[43,1656,1658],{"class":45,"line":1657},37,[43,1659,67],{"emptyLinePlaceholder":66},[43,1661,1663],{"class":45,"line":1662},38,[43,1664,1665],{"class":484},"# 4. searching\n",[43,1667,1669,1671],{"class":45,"line":1668},39,[43,1670,1425],{"class":49},[43,1672,1673],{"class":53}," \"Running find and grep examples\"\n",[43,1675,1677,1679,1681,1683],{"class":45,"line":1676},40,[43,1678,883],{"class":49},[43,1680,427],{"class":53},[43,1682,904],{"class":97},[43,1684,1685],{"class":53}," \"*.md\"\n",[43,1687,1689,1691,1693,1696],{"class":45,"line":1688},41,[43,1690,1043],{"class":49},[43,1692,618],{"class":97},[43,1694,1695],{"class":53}," \"Linux\"",[43,1697,685],{"class":53},[43,1699,1701],{"class":45,"line":1700},42,[43,1702,67],{"emptyLinePlaceholder":66},[43,1704,1706,1708],{"class":45,"line":1705},43,[43,1707,1425],{"class":49},[43,1709,1710],{"class":53}," \"Done.\"\n",[238,1712],{},[11,1714,1715,1718,1719,1721,1722,1725],{},[18,1716,1717],{},"set -e"," makes the script exit immediately if any command fails. This is important in automation. Without it, a failed ",[18,1720,335],{}," would let the script continue and produce confusing results. ",[18,1723,1724],{},"tee -a"," writes to both stdout and the log file simultaneously.",[23,1727],{},[26,1729,1731],{"id":1730},"what-to-read","What to Read",[11,1733,1734],{},"The Linux command line is deep. Two resources worth your time:",[11,1736,1737,1741],{},[1738,1739,1740],"strong",{},"The Linux Command Line"," by William Shotts is available free at linuxcommand.org and covers everything in this task in more depth. It is practical, direct, and does not assume you already know everything.",[11,1743,1744,1747],{},[1738,1745,1746],{},"Unix and Linux System Administration Handbook"," by Evi Nemeth is the reference for when you move beyond basics into configuring systems for real workloads. It is dense and thorough.",[11,1749,1750],{},"The commands in this task are not the interesting part. The interesting part is understanding why the filesystem is structured the way it is, why permissions exist in three groups, why symlinks are a deployment primitive and not just a shortcut. That understanding is what makes the difference between someone who can follow instructions and someone who can debug a broken system at 2 AM.",[23,1752],{},[1754,1755,1756,1766,1773,1780],"ul",{},[1757,1758,1759,1760],"li",{},"The Linux Command Line, William Shotts - ",[1761,1762,1763],"a",{"href":1763,"rel":1764},"https://linuxcommand.org",[1765],"nofollow",[1757,1767,1768,1769],{},"Filesystem Hierarchy Standard - ",[1761,1770,1771],{"href":1771,"rel":1772},"https://refspecs.linuxfoundation.org/FHS_3.0/fhs/index.html",[1765],[1757,1774,1775,1776],{},"Linux File Permissions Explained - ",[1761,1777,1778],{"href":1778,"rel":1779},"https://redhat.com/sysadmin/linux-file-permissions-explained",[1765],[1757,1781,1782,1783],{},"DevOpsDiary Task 03 - ",[1761,1784,1785],{"href":1785,"rel":1786},"https://devopsdiary.site/beginner/03_linux_basics",[1765],[1788,1789,1790],"sty
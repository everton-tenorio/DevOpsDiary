[{"data":1,"prerenderedAt":1814},["ShallowReactive",2],{"/blog/linux-basics":3},{"id":4,"title":5,"bannerImage":6,"body":7,"date":1802,"description":13,"extension":1803,"meta":1804,"navigation":66,"path":1806,"seo":1807,"stem":1808,"tags":1809,"__hash__":1813},"posts/blog/linux-basics.md","Linux Basics","/blog/linux-basics.png",{"type":8,"value":9,"toc":1791},"minimark",[10,14,22,25,30,33,237,240,254,264,267,269,273,276,284,286,303,311,317,319,323,326,342,344,354,367,408,410,413,464,466,468,472,475,568,570,593,596,649,651,660,662,666,669,730,732,738,744,746,749,755,757,775,855,857,870,872,876,879,885,1020,1022,1039,1045,1157,1159,1168,1176,1211,1213,1223,1225,1229,1232,1251,1253,1302,1304,1317,1331,1334,1336,1340,1343,1711,1713,1726,1728,1732,1735,1742,1748,1751,1753,1787],[11,12,13],"p",{},"This guide covers Linux basics, turning isolated commands into a practical foundation for starting in automation workflows.",[11,15,16,17,21],{},"This is Task 03 of the DevOpsDiary beginner path. The deliverable is a Bash script called ",[18,19,20],"code",{},"linux-basics.sh"," that demonstrates core filesystem operations. By the time you finish this post, you will understand not just the commands, but the reasoning behind them.",[23,24],"hr",{},[26,27,29],"h2",{"id":28},"you-just-landed-on-a-server-you-have-never-seen-before","You Just Landed on a Server You Have Never Seen Before",[11,31,32],{},"This happens constantly in DevOps work. A new machine, a colleague's environment, a cloud instance that was provisioned before you joined the team. The first thing you do is orient yourself.",[34,35,40],"pre",{"className":36,"code":37,"language":38,"meta":39,"style":39},"language-bash shiki shiki-themes github-light github-dark","$ pwd\n/home/everton\n\n$ whoami\neverton\n\n$ ls -la\ntotal 48\ndrwxr-xr-x 6 everton everton 4096 Mar 22 14:31 .\ndrwxr-xr-x 3 root    root    4096 Mar 10 09:12 ..\n-rw-r--r-- 1 everton everton  220 Mar 10 09:12 .bash_logout\n-rw-r--r-- 1 everton everton 3526 Mar 10 09:12 .bashrc\ndrwxr-xr-x 2 everton everton 4096 Mar 22 14:28 projects\n","bash","",[18,41,42,55,61,68,76,82,87,99,108,137,165,190,213],{"__ignoreMap":39},[43,44,47,51],"span",{"class":45,"line":46},"line",1,[43,48,50],{"class":49},"sScJk","$",[43,52,54],{"class":53},"sZZnC"," pwd\n",[43,56,58],{"class":45,"line":57},2,[43,59,60],{"class":49},"/home/everton\n",[43,62,64],{"class":45,"line":63},3,[43,65,67],{"emptyLinePlaceholder":66},true,"\n",[43,69,71,73],{"class":45,"line":70},4,[43,72,50],{"class":49},[43,74,75],{"class":53}," whoami\n",[43,77,79],{"class":45,"line":78},5,[43,80,81],{"class":49},"everton\n",[43,83,85],{"class":45,"line":84},6,[43,86,67],{"emptyLinePlaceholder":66},[43,88,90,92,95],{"class":45,"line":89},7,[43,91,50],{"class":49},[43,93,94],{"class":53}," ls",[43,96,98],{"class":97},"sj4cs"," -la\n",[43,100,102,105],{"class":45,"line":101},8,[43,103,104],{"class":49},"total",[43,106,107],{"class":97}," 48\n",[43,109,111,114,117,120,122,125,128,131,134],{"class":45,"line":110},9,[43,112,113],{"class":49},"drwxr-xr-x",[43,115,116],{"class":97}," 6",[43,118,119],{"class":53}," everton",[43,121,119],{"class":53},[43,123,124],{"class":97}," 4096",[43,126,127],{"class":53}," Mar",[43,129,130],{"class":97}," 22",[43,132,133],{"class":53}," 14:31",[43,135,136],{"class":53}," .\n",[43,138,140,142,145,148,151,154,156,159,162],{"class":45,"line":139},10,[43,141,113],{"class":49},[43,143,144],{"class":97}," 3",[43,146,147],{"class":53}," root",[43,149,150],{"class":53},"    root",[43,152,153],{"class":97},"    4096",[43,155,127],{"class":53},[43,157,158],{"class":97}," 10",[43,160,161],{"class":53}," 09:12",[43,163,164],{"class":53}," ..\n",[43,166,168,171,174,176,178,181,183,185,187],{"class":45,"line":167},11,[43,169,170],{"class":49},"-rw-r--r--",[43,172,173],{"class":97}," 1",[43,175,119],{"class":53},[43,177,119],{"class":53},[43,179,180],{"class":97},"  220",[43,182,127],{"class":53},[43,184,158],{"class":97},[43,186,161],{"class":53},[43,188,189],{"class":53}," .bash_logout\n",[43,191,193,195,197,199,201,204,206,208,210],{"class":45,"line":192},12,[43,194,170],{"class":49},[43,196,173],{"class":97},[43,198,119],{"class":53},[43,200,119],{"class":53},[43,202,203],{"class":97}," 3526",[43,205,127],{"class":53},[43,207,158],{"class":97},[43,209,161],{"class":53},[43,211,212],{"class":53}," .bashrc\n",[43,214,216,218,221,223,225,227,229,231,234],{"class":45,"line":215},13,[43,217,113],{"class":49},[43,219,220],{"class":97}," 2",[43,222,119],{"class":53},[43,224,119],{"class":53},[43,226,124],{"class":97},[43,228,127],{"class":53},[43,230,130],{"class":97},[43,232,233],{"class":53}," 14:28",[43,235,236],{"class":53}," projects\n",[238,239],"br",{},[11,241,242,245,246,249,250,253],{},[18,243,244],{},"pwd"," tells you where you are. ",[18,247,248],{},"whoami"," tells you who the system thinks you are. ",[18,251,252],{},"ls -la"," tells you what is here and who owns it.",[11,255,256,257,259,260,263],{},"That last column before the filename is not decoration. It is information. ",[18,258,113],{}," means directory, owner can read/write/execute, group can read/execute, others can read/execute. ",[18,261,262],{},"everton everton"," means the owner is everton and the group is everton. The date tells you when it was last modified.",[11,265,266],{},"You read that output every time you land somewhere new. It takes three seconds and saves you from operating blind.",[23,268],{},[26,270,272],{"id":271},"the-filesystem-hierarchy-where-things-live","The Filesystem Hierarchy: Where Things Live",[11,274,275],{},"Linux follows a standard called the Filesystem Hierarchy Standard. Every distribution puts things in roughly the same places. Knowing this means you are not lost on any Linux system, regardless of whether it is Ubuntu, Debian, Devuan, or CentOS.",[34,277,282],{"className":278,"code":280,"language":281},[279],"language-text","/\n├── /bin      essential binaries available to all users (ls, cp, bash)\n├── /etc      system configuration files\n├── /home     user home directories\n├── /var      variable data: logs, caches, mail spools\n├── /tmp      temporary files, cleared on reboot\n├── /proc     virtual filesystem with live kernel state\n├── /dev      devices represented as files\n├── /usr      user programs, libraries, documentation\n└── /opt      optional and third-party software\n","text",[18,283,280],{"__ignoreMap":39},[238,285],{},[11,287,288,291,292,295,296,299,300,302],{},[18,289,290],{},"/etc"," is where you will spend a significant amount of time. Every service on the system has its configuration there. SSH lives at ",[18,293,294],{},"/etc/ssh/sshd_config",". Nginx lives at ",[18,297,298],{},"/etc/nginx/",". Network configuration, user management, cron jobs — all in ",[18,301,290],{},".",[11,304,305,308,309,302],{},[18,306,307],{},"/var/log"," is where you go when something breaks. System logs, application logs, authentication logs. The answer to most production incidents is somewhere in ",[18,310,307],{},[11,312,313,316],{},[18,314,315],{},"/proc"," you already know from Task 02. It is not a real directory. The kernel writes it in memory and everything in it reflects the live state of the system.",[23,318],{},[26,320,322],{"id":321},"building-a-project-structure","Building a Project Structure",[11,324,325],{},"The task requires creating a nested directory structure from scratch. This is one of the most common operations in any automation script.",[34,327,329],{"className":36,"code":328,"language":38,"meta":39,"style":39},"mkdir -p project/{docs,src/{modules,config},logs}\n",[18,330,331],{"__ignoreMap":39},[43,332,333,336,339],{"class":45,"line":46},[43,334,335],{"class":49},"mkdir",[43,337,338],{"class":97}," -p",[43,340,341],{"class":53}," project/{docs,src/{modules,config},logs}\n",[238,343],{},[11,345,346,347,350,351,353],{},"The ",[18,348,349],{},"-p"," flag does two things: it creates parent directories as needed, and it does not fail if the directory already exists. Without ",[18,352,349],{},", you would need to create each directory individually in the right order. With it, one command creates the entire tree.",[11,355,356,357,360,361,363,364,366],{},"The brace expansion ",[18,358,359],{},"{docs,src/{modules,config},logs}"," is a shell feature, not a ",[18,362,335],{}," feature. The shell expands it before passing the arguments to ",[18,365,335],{},". The result is equivalent to running:",[34,368,370],{"className":36,"code":369,"language":38,"meta":39,"style":39},"mkdir -p project/docs\nmkdir -p project/src/modules\nmkdir -p project/src/config\nmkdir -p project/logs\n",[18,371,372,381,390,399],{"__ignoreMap":39},[43,373,374,376,378],{"class":45,"line":46},[43,375,335],{"class":49},[43,377,338],{"class":97},[43,379,380],{"class":53}," project/docs\n",[43,382,383,385,387],{"class":45,"line":57},[43,384,335],{"class":49},[43,386,338],{"class":97},[43,388,389],{"class":53}," project/src/modules\n",[43,391,392,394,396],{"class":45,"line":63},[43,393,335],{"class":49},[43,395,338],{"class":97},[43,397,398],{"class":53}," project/src/config\n",[43,400,401,403,405],{"class":45,"line":70},[43,402,335],{"class":49},[43,404,338],{"class":97},[43,406,407],{"class":53}," project/logs\n",[238,409],{},[11,411,412],{},"Verify the result:",[34,414,416],{"className":36,"code":415,"language":38,"meta":39,"style":39},"$ find project -type d\nproject\nproject/docs\nproject/src\nproject/src/modules\nproject/src/config\nproject/logs\n",[18,417,418,434,439,444,449,454,459],{"__ignoreMap":39},[43,419,420,422,425,428,431],{"class":45,"line":46},[43,421,50],{"class":49},[43,423,424],{"class":53}," find",[43,426,427],{"class":53}," project",[43,429,430],{"class":97}," -type",[43,432,433],{"class":53}," d\n",[43,435,436],{"class":45,"line":57},[43,437,438],{"class":49},"project\n",[43,440,441],{"class":45,"line":63},[43,442,443],{"class":49},"project/docs\n",[43,445,446],{"class":45,"line":70},[43,447,448],{"class":49},"project/src\n",[43,450,451],{"class":45,"line":78},[43,452,453],{"class":49},"project/src/modules\n",[43,455,456],{"class":45,"line":84},[43,457,458],{"class":49},"project/src/config\n",[43,460,461],{"class":45,"line":89},[43,462,463],{"class":49},"project/logs\n",[238,465],{},[23,467],{},[26,469,471],{"id":470},"file-operations","File Operations",[11,473,474],{},"Once you have a structure, you need to populate it and move things around. Linux gives you several ways to create files depending on what you need.",[34,476,478],{"className":36,"code":477,"language":38,"meta":39,"style":39},"# create an empty file\ntouch project/docs/README.md\n\n# create a file with content\necho \"# Linux Basics Project\" > project/docs/README.md\n\n# create a file with multiple lines\ncat > project/docs/notes.txt \u003C\u003C EOF\nTask: linux-basics.sh\nAuthor: everton\nDate: $(date +%Y-%m-%d)\nEOF\n",[18,479,480,486,494,498,503,517,521,526,542,547,552,563],{"__ignoreMap":39},[43,481,482],{"class":45,"line":46},[43,483,485],{"class":484},"sJ8bj","# create an empty file\n",[43,487,488,491],{"class":45,"line":57},[43,489,490],{"class":49},"touch",[43,492,493],{"class":53}," project/docs/README.md\n",[43,495,496],{"class":45,"line":63},[43,497,67],{"emptyLinePlaceholder":66},[43,499,500],{"class":45,"line":70},[43,501,502],{"class":484},"# create a file with content\n",[43,504,505,508,511,515],{"class":45,"line":78},[43,506,507],{"class":97},"echo",[43,509,510],{"class":53}," \"# Linux Basics Project\"",[43,512,514],{"class":513},"szBVR"," >",[43,516,493],{"class":53},[43,518,519],{"class":45,"line":84},[43,520,67],{"emptyLinePlaceholder":66},[43,522,523],{"class":45,"line":89},[43,524,525],{"class":484},"# create a file with multiple lines\n",[43,527,528,531,533,536,539],{"class":45,"line":101},[43,529,530],{"class":49},"cat",[43,532,514],{"class":513},[43,534,535],{"class":53}," project/docs/notes.txt",[43,537,538],{"class":513}," \u003C\u003C",[43,540,541],{"class":53}," EOF\n",[43,543,544],{"class":45,"line":110},[43,545,546],{"class":53},"Task: linux-basics.sh\n",[43,548,549],{"class":45,"line":139},[43,550,551],{"class":53},"Author: everton\n",[43,553,554,557,560],{"class":45,"line":167},[43,555,556],{"class":53},"Date: $(",[43,558,559],{"class":49},"date",[43,561,562],{"class":53}," +%Y-%m-%d)\n",[43,564,565],{"class":45,"line":192},[43,566,567],{"class":53},"EOF\n",[238,569],{},[11,571,572,574,575,577,578,581,582,585,586,588,589,592],{},[18,573,490],{}," creates an empty file or updates the timestamp of an existing one. ",[18,576,507],{}," with ",[18,579,580],{},">"," creates a file with a single line, overwriting if it exists. ",[18,583,584],{},">>"," appends instead of overwriting. ",[18,587,530],{}," with a here-document (",[18,590,591],{},"\u003C\u003C EOF",") lets you write multiple lines inline.",[11,594,595],{},"Copying and moving:",[34,597,599],{"className":36,"code":598,"language":38,"meta":39,"style":39},"cp project/docs/README.md project/src/README.md\ncp -r project/docs/ project/docs_backup/\n\nmv project/docs/notes.txt project/docs/NOTES.md\nmv project/docs_backup/ project/archive/\n",[18,600,601,612,625,629,639],{"__ignoreMap":39},[43,602,603,606,609],{"class":45,"line":46},[43,604,605],{"class":49},"cp",[43,607,608],{"class":53}," project/docs/README.md",[43,610,611],{"class":53}," project/src/README.md\n",[43,613,614,616,619,622],{"class":45,"line":57},[43,615,605],{"class":49},[43,617,618],{"class":97}," -r",[43,620,621],{"class":53}," project/docs/",[43,623,624],{"class":53}," project/docs_backup/\n",[43,626,627],{"class":45,"line":63},[43,628,67],{"emptyLinePlaceholder":66},[43,630,631,634,636],{"class":45,"line":70},[43,632,633],{"class":49},"mv",[43,635,535],{"class":53},[43,637,638],{"class":53}," project/docs/NOTES.md\n",[43,640,641,643,646],{"class":45,"line":78},[43,642,633],{"class":49},[43,644,645],{"class":53}," project/docs_backup/",[43,647,648],{"class":53}," project/archive/\n",[238,650],{},[11,652,653,656,657,659],{},[18,654,655],{},"cp -r"," copies recursively, which is required for directories. ",[18,658,633],{}," works for both files and directories without a flag, and it also serves as rename when source and destination are in the same directory.",[23,661],{},[26,663,665],{"id":664},"permissions-who-can-do-what","Permissions: Who Can Do What",[11,667,668],{},"Every file and directory in Linux has three permission sets: owner, group, and others. Each set has three bits: read, write, execute.",[34,670,672],{"className":36,"code":671,"language":38,"meta":39,"style":39},"$ ls -la project/\n-rw-r--r-- 1 everton everton  24 Mar 22 14:45 README.md\ndrwxr-xr-x 2 everton everton 4096 Mar 22 14:31 src/\n",[18,673,674,686,709],{"__ignoreMap":39},[43,675,676,678,680,683],{"class":45,"line":46},[43,677,50],{"class":49},[43,679,94],{"class":53},[43,681,682],{"class":97}," -la",[43,684,685],{"class":53}," project/\n",[43,687,688,690,692,694,696,699,701,703,706],{"class":45,"line":57},[43,689,170],{"class":49},[43,691,173],{"class":97},[43,693,119],{"class":53},[43,695,119],{"class":53},[43,697,698],{"class":97},"  24",[43,700,127],{"class":53},[43,702,130],{"class":97},[43,704,705],{"class":53}," 14:45",[43,707,708],{"class":53}," README.md\n",[43,710,711,713,715,717,719,721,723,725,727],{"class":45,"line":63},[43,712,113],{"class":49},[43,714,220],{"class":97},[43,716,119],{"class":53},[43,718,119],{"class":53},[43,720,124],{"class":97},[43,722,127],{"class":53},[43,724,130],{"class":97},[43,726,133],{"class":53},[43,728,729],{"class":53}," src/\n",[238,731],{},[11,733,734,735,737],{},"Breaking down ",[18,736,170],{},":",[34,739,742],{"className":740,"code":741,"language":281},[279],"- rw- r-- r--\n│ │   │   └── others: read only\n│ │   └────── group: read only\n│ └────────── owner: read and write\n└──────────── file type (- = regular file, d = directory)\n",[18,743,741],{"__ignoreMap":39},[238,745],{},[11,747,748],{},"The numeric representation maps directly to binary. Read is 4, write is 2, execute is 1. You add them for each group:",[34,750,753],{"className":751,"code":752,"language":281},[279],"7 = 4+2+1 = rwx\n6 = 4+2+0 = rw-\n5 = 4+0+1 = r-x\n4 = 4+0+0 = r--\n",[18,754,752],{"__ignoreMap":39},[238,756],{},[11,758,759,760,763,764,767,768,763,771,774],{},"So ",[18,761,762],{},"chmod 755"," sets ",[18,765,766],{},"rwxr-xr-x",". ",[18,769,770],{},"chmod 644",[18,772,773],{},"rw-r--r--",". These two cover the vast majority of cases. Scripts that need to run get 755. Configuration files that should only be readable by the owner get 600. Web server static files typically get 644.",[34,776,778],{"className":36,"code":777,"language":38,"meta":39,"style":39},"# make the script executable\nchmod +x linux-basics.sh\n\n# numeric notation\nchmod 755 linux-basics.sh\nchmod 644 project/docs/README.md\n\n# change ownership\nchown everton:everton project/docs/README.md\nchown -R everton:www-data project/src/\n",[18,779,780,785,796,800,805,814,823,827,832,842],{"__ignoreMap":39},[43,781,782],{"class":45,"line":46},[43,783,784],{"class":484},"# make the script executable\n",[43,786,787,790,793],{"class":45,"line":57},[43,788,789],{"class":49},"chmod",[43,791,792],{"class":53}," +x",[43,794,795],{"class":53}," linux-basics.sh\n",[43,797,798],{"class":45,"line":63},[43,799,67],{"emptyLinePlaceholder":66},[43,801,802],{"class":45,"line":70},[43,803,804],{"class":484},"# numeric notation\n",[43,806,807,809,812],{"class":45,"line":78},[43,808,789],{"class":49},[43,810,811],{"class":97}," 755",[43,813,795],{"class":53},[43,815,816,818,821],{"class":45,"line":84},[43,817,789],{"class":49},[43,819,820],{"class":97}," 644",[43,822,493],{"class":53},[43,824,825],{"class":45,"line":89},[43,826,67],{"emptyLinePlaceholder":66},[43,828,829],{"class":45,"line":101},[43,830,831],{"class":484},"# change ownership\n",[43,833,834,837,840],{"class":45,"line":110},[43,835,836],{"class":49},"chown",[43,838,839],{"class":53}," everton:everton",[43,841,493],{"class":53},[43,843,844,846,849,852],{"class":45,"line":139},[43,845,836],{"class":49},[43,847,848],{"class":97}," -R",[43,850,851],{"class":53}," everton:www-data",[43,853,854],{"class":53}," project/src/\n",[238,856],{},[11,858,859,862,863,866,867,869],{},[18,860,861],{},"chown -R"," changes ownership recursively. The ",[18,864,865],{},"user:group"," syntax sets both at once. When you are configuring a web server, you often need files owned by the deploy user but readable by the web server group. This is where ",[18,868,836],{}," with group assignment becomes important.",[23,871],{},[26,873,875],{"id":874},"finding-things","Finding Things",[11,877,878],{},"A production server can have hundreds of thousands of files. You need to be able to find what you are looking for without browsing directories manually.",[11,880,881,884],{},[18,882,883],{},"find"," searches by file attributes: name, type, size, age, permissions.",[34,886,888],{"className":36,"code":887,"language":38,"meta":39,"style":39},"# find all log files under /var\nfind /var/log -name \"*.log\"\n\n# find files modified in the last 7 days\nfind . -type f -mtime -7\n\n# find world-writable files (security concern)\nfind /etc -perm -o+w\n\n# find and delete files older than 30 days\nfind /tmp -type f -mtime +30 -delete\n\n# find and execute a command on each result\nfind . -name \"*.sh\" -exec chmod +x {} \\;\n",[18,889,890,895,908,912,917,935,939,944,957,961,966,985,989,994],{"__ignoreMap":39},[43,891,892],{"class":45,"line":46},[43,893,894],{"class":484},"# find all log files under /var\n",[43,896,897,899,902,905],{"class":45,"line":57},[43,898,883],{"class":49},[43,900,901],{"class":53}," /var/log",[43,903,904],{"class":97}," -name",[43,906,907],{"class":53}," \"*.log\"\n",[43,909,910],{"class":45,"line":63},[43,911,67],{"emptyLinePlaceholder":66},[43,913,914],{"class":45,"line":70},[43,915,916],{"class":484},"# find files modified in the last 7 days\n",[43,918,919,921,924,926,929,932],{"class":45,"line":78},[43,920,883],{"class":49},[43,922,923],{"class":53}," .",[43,925,430],{"class":97},[43,927,928],{"class":53}," f",[43,930,931],{"class":97}," -mtime",[43,933,934],{"class":97}," -7\n",[43,936,937],{"class":45,"line":84},[43,938,67],{"emptyLinePlaceholder":66},[43,940,941],{"class":45,"line":89},[43,942,943],{"class":484},"# find world-writable files (security concern)\n",[43,945,946,948,951,954],{"class":45,"line":101},[43,947,883],{"class":49},[43,949,950],{"class":53}," /etc",[43,952,953],{"class":97}," -perm",[43,955,956],{"class":97}," -o+w\n",[43,958,959],{"class":45,"line":110},[43,960,67],{"emptyLinePlaceholder":66},[43,962,963],{"class":45,"line":139},[43,964,965],{"class":484},"# find and delete files older than 30 days\n",[43,967,968,970,973,975,977,979,982],{"class":45,"line":167},[43,969,883],{"class":49},[43,971,972],{"class":53}," /tmp",[43,974,430],{"class":97},[43,976,928],{"class":53},[43,978,931],{"class":97},[43,980,981],{"class":53}," +30",[43,983,984],{"class":97}," -delete\n",[43,986,987],{"class":45,"line":192},[43,988,67],{"emptyLinePlaceholder":66},[43,990,991],{"class":45,"line":215},[43,992,993],{"class":484},"# find and execute a command on each result\n",[43,995,997,999,1001,1003,1006,1009,1012,1014,1017],{"class":45,"line":996},14,[43,998,883],{"class":49},[43,1000,923],{"class":53},[43,1002,904],{"class":97},[43,1004,1005],{"class":53}," \"*.sh\"",[43,1007,1008],{"class":97}," -exec",[43,1010,1011],{"class":53}," chmod",[43,1013,792],{"class":53},[43,1015,1016],{"class":53}," {}",[43,1018,1019],{"class":97}," \\;\n",[238,1021],{},[11,1023,346,1024,1027,1028,1030,1031,1034,1035,1038],{},[18,1025,1026],{},"-exec"," flag is where ",[18,1029,883],{}," becomes genuinely powerful. ",[18,1032,1033],{},"{}"," is replaced by each found file, and ",[18,1036,1037],{},"\\;"," ends the command. This pattern shows up constantly in automation scripts.",[11,1040,1041,1044],{},[18,1042,1043],{},"grep"," searches inside files.",[34,1046,1048],{"className":36,"code":1047,"language":38,"meta":39,"style":39},"# search recursively for a string\ngrep -r \"PermitRootLogin\" /etc/ssh/\n\n# show line numbers\ngrep -n \"error\" /var/log/syslog\n\n# invert match: show lines that do NOT match\ngrep -v \"^#\" /etc/ssh/sshd_config\n\n# case insensitive\ngrep -i \"failed\" /var/log/auth.log\n\n# search with context (3 lines before and after)\ngrep -B3 -A3 \"segfault\" /var/log/syslog\n",[18,1049,1050,1055,1067,1071,1076,1089,1093,1098,1111,1115,1120,1133,1137,1142],{"__ignoreMap":39},[43,1051,1052],{"class":45,"line":46},[43,1053,1054],{"class":484},"# search recursively for a string\n",[43,1056,1057,1059,1061,1064],{"class":45,"line":57},[43,1058,1043],{"class":49},[43,1060,618],{"class":97},[43,1062,1063],{"class":53}," \"PermitRootLogin\"",[43,1065,1066],{"class":53}," /etc/ssh/\n",[43,1068,1069],{"class":45,"line":63},[43,1070,67],{"emptyLinePlaceholder":66},[43,1072,1073],{"class":45,"line":70},[43,1074,1075],{"class":484},"# show line numbers\n",[43,1077,1078,1080,1083,1086],{"class":45,"line":78},[43,1079,1043],{"class":49},[43,1081,1082],{"class":97}," -n",[43,1084,1085],{"class":53}," \"error\"",[43,1087,1088],{"class":53}," /var/log/syslog\n",[43,1090,1091],{"class":45,"line":84},[43,1092,67],{"emptyLinePlaceholder":66},[43,1094,1095],{"class":45,"line":89},[43,1096,1097],{"class":484},"# invert match: show lines that do NOT match\n",[43,1099,1100,1102,1105,1108],{"class":45,"line":101},[43,1101,1043],{"class":49},[43,1103,1104],{"class":97}," -v",[43,1106,1107],{"class":53}," \"^#\"",[43,1109,1110],{"class":53}," /etc/ssh/sshd_config\n",[43,1112,1113],{"class":45,"line":110},[43,1114,67],{"emptyLinePlaceholder":66},[43,1116,1117],{"class":45,"line":139},[43,1118,1119],{"class":484},"# case insensitive\n",[43,1121,1122,1124,1127,1130],{"class":45,"line":167},[43,1123,1043],{"class":49},[43,1125,1126],{"class":97}," -i",[43,1128,1129],{"class":53}," \"failed\"",[43,1131,1132],{"class":53}," /var/log/auth.log\n",[43,1134,1135],{"class":45,"line":192},[43,1136,67],{"emptyLinePlaceholder":66},[43,1138,1139],{"class":45,"line":215},[43,1140,1141],{"class":484},"# search with context (3 lines before and after)\n",[43,1143,1144,1146,1149,1152,1155],{"class":45,"line":996},[43,1145,1043],{"class":49},[43,1147,1148],{"class":97}," -B3",[43,1150,1151],{"class":97}," -A3",[43,1153,1154],{"class":53}," \"segfault\"",[43,1156,1088],{"class":53},[238,1158],{},[11,1160,1161,1164,1165,1167],{},[18,1162,1163],{},"grep -v \"^#\""," is particularly useful for reading configuration files. Most config files have extensive comments. ",[18,1166,1163],{}," removes all comment lines and shows only the active configuration, which is usually what you need when you are diagnosing why a service is behaving a certain way.",[11,1169,1170,1171,1173,1174,737],{},"Combining ",[18,1172,883],{}," and ",[18,1175,1043],{},[34,1177,1179],{"className":36,"code":1178,"language":38,"meta":39,"style":39},"# find all scripts containing a specific function\nfind . -name \"*.sh\" | xargs grep -l \"deploy_app\"\n",[18,1180,1181,1186],{"__ignoreMap":39},[43,1182,1183],{"class":45,"line":46},[43,1184,1185],{"class":484},"# find all scripts containing a specific function\n",[43,1187,1188,1190,1192,1194,1196,1199,1202,1205,1208],{"class":45,"line":57},[43,1189,883],{"class":49},[43,1191,923],{"class":53},[43,1193,904],{"class":97},[43,1195,1005],{"class":53},[43,1197,1198],{"class":513}," |",[43,1200,1201],{"class":49}," xargs",[43,1203,1204],{"class":53}," grep",[43,1206,1207],{"class":97}," -l",[43,1209,1210],{"class":53}," \"deploy_app\"\n",[238,1212],{},[11,1214,1215,1218,1219,1222],{},[18,1216,1217],{},"xargs"," takes lines from standard input and passes them as arguments to the next command. This pattern, ",[18,1220,1221],{},"find | xargs grep",", is one of the most useful combinations in the Linux toolkit.",[23,1224],{},[26,1226,1228],{"id":1227},"symbolic-links","Symbolic Links",[11,1230,1231],{},"A symbolic link is a file that points to another file or directory. The link itself contains only the path to the target. When you access the link, the kernel follows the pointer and gives you the target.",[34,1233,1235],{"className":36,"code":1234,"language":38,"meta":39,"style":39},"ln -s /opt/myapp/config/nginx.conf /etc/nginx/nginx.conf\n",[18,1236,1237],{"__ignoreMap":39},[43,1238,1239,1242,1245,1248],{"class":45,"line":46},[43,1240,1241],{"class":49},"ln",[43,1243,1244],{"class":97}," -s",[43,1246,1247],{"class":53}," /opt/myapp/config/nginx.conf",[43,1249,1250],{"class":53}," /etc/nginx/nginx.conf\n",[238,1252],{},[34,1254,1256],{"className":36,"code":1255,"language":38,"meta":39,"style":39},"$ ls -la /etc/nginx/\nlrwxrwxrwx 1 root root 32 Mar 22 15:00 nginx.conf -> /opt/myapp/config/nginx.conf\n",[18,1257,1258,1269],{"__ignoreMap":39},[43,1259,1260,1262,1264,1266],{"class":45,"line":46},[43,1261,50],{"class":49},[43,1263,94],{"class":53},[43,1265,682],{"class":97},[43,1267,1268],{"class":53}," /etc/nginx/\n",[43,1270,1271,1274,1276,1278,1280,1283,1285,1287,1290,1293,1297,1299],{"class":45,"line":57},[43,1272,1273],{"class":49},"lrwxrwxrwx",[43,1275,173],{"class":97},[43,1277,147],{"class":53},[43,1279,147],{"class":53},[43,1281,1282],{"class":97}," 32",[43,1284,127],{"class":53},[43,1286,130],{"class":97},[43,1288,1289],{"class":53}," 15:00",[43,1291,1292],{"class":53}," nginx.conf",[43,1294,1296],{"class":1295},"sVt8B"," -",[43,1298,580],{"class":513},[43,1300,1301],{"class":53}," /opt/myapp/config/nginx.conf\n",[238,1303],{},[11,1305,346,1306,1309,1310,1312,1313,1316],{},[18,1307,1308],{},"l"," at the start of ",[18,1311,1273],{}," indicates a symlink. The ",[18,1314,1315],{},"->"," shows where it points.",[11,1318,1319,1320,1323,1324,1327,1328,1330],{},"Why does this matter in practice? In deployment workflows, symlinks let you switch between versions atomically. You deploy the new version to ",[18,1321,1322],{},"/opt/myapp/releases/v2.1.0/",", then update the symlink from ",[18,1325,1326],{},"/opt/myapp/current"," to point to the new release. All processes that reference ",[18,1329,1326],{}," immediately see the new version. If something is wrong, you change the symlink back. No files were moved or copied during the switch.",[11,1332,1333],{},"This is the pattern used by Capistrano, by many deploy scripts, and by tools like systemd for managing alternative binaries.",[23,1335],{},[26,1337,1339],{"id":1338},"putting-it-together-linux-basicssh","Putting It Together: linux-basics.sh",[11,1341,1342],{},"The complete script combines all of the above into a single executable that can be run on any Linux system to demonstrate each concept.",[34,1344,1346],{"className":36,"code":1345,"language":38,"meta":39,"style":39},"#!/bin/bash\n\n# linux-basics.sh\n# Task 03 - DevOpsDiary beginner path\n# Demonstrates core Linux filesystem operations\n\nset -e\n\nTIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')\nLOG_FILE=\"linux-basics.log\"\n\nlog() {\n    echo \"[$TIMESTAMP] $1\" | tee -a \"$LOG_FILE\"\n}\n\necho \"======================================\"\necho \"  LINUX BASICS — $TIMESTAMP\"\necho \"======================================\"\n\n# 1. directory structure\nlog \"Creating project directory structure\"\nmkdir -p project/{docs,src/{modules,config},logs}\nfind project -type d\n\n# 2. file operations\nlog \"Creating and manipulating files\"\ntouch project/docs/README.md\necho \"# Linux Basics Project\" > project/docs/README.md\ncp project/docs/README.md project/src/README.md\nln -sf \"$(pwd)/project/src/config\" project/config_link\n\n# 3. permissions\nlog \"Setting permissions\"\nchmod 755 linux-basics.sh\nchmod 644 project/docs/README.md\nls -la project/docs/\n\n# 4. searching\nlog \"Running find and grep examples\"\nfind project -name \"*.md\"\ngrep -r \"Linux\" project/\n\nlog \"Done.\"\n",[18,1347,1348,1353,1357,1362,1367,1372,1376,1384,1388,1407,1417,1421,1429,1466,1471,1476,1484,1496,1503,1508,1514,1522,1531,1542,1547,1553,1561,1568,1579,1588,1607,1612,1618,1626,1635,1644,1655,1660,1666,1674,1686,16